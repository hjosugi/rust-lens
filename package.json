{
  "name": "rust-ownership-lens",
  "displayName": "Rust Ownership Lens",
  "description": "Explain Rust ownership, borrowing, lifetime, iterator, and async errors with ASCII timelines.",
  "version": "0.1.0",
  "publisher": "hjosugi",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/hjosugi/rust-lens.git"
  },
  "bugs": {
    "url": "https://github.com/hjosugi/rust-lens/issues"
  },
  "homepage": "https://github.com/hjosugi/rust-lens#readme",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Education"
  ],
  "keywords": [
    "rust",
    "ownership",
    "borrow-checker",
    "lifetime",
    "cargo",
    "ascii"
  ],
  "main": "./extension.js",
  "scripts": {
    "test": "node --test",
    "test:rust-compat": "node scripts/check-rust-compat.js",
    "package": "vsce package --out rust-ownership-lens-${npm_package_version}.vsix",
    "package:offline": "bash scripts/package-vsix.sh",
    "install-local": "bash scripts/install-local.sh"
  },
  "activationEvents": [
    "onLanguage:rust",
    "onCommand:rustOwnershipLens.runCheck",
    "onCommand:rustOwnershipLens.explainSelection",
    "onCommand:rustOwnershipLens.showPanel",
    "onView:rustOwnershipLens.view"
  ],
  "contributes": {
    "commands": [
      {
        "command": "rustOwnershipLens.runCheck",
        "title": "Rust Ownership Lens: Run cargo check"
      },
      {
        "command": "rustOwnershipLens.explainSelection",
        "title": "Rust Ownership Lens: Explain Selected Rust Code"
      },
      {
        "command": "rustOwnershipLens.showPanel",
        "title": "Rust Ownership Lens: Show Panel"
      },
      {
        "command": "rustOwnershipLens.copyLastExplanation",
        "title": "Rust Ownership Lens: Copy Last Explanation"
      },
      {
        "command": "rustOwnershipLens.insertExample",
        "title": "Rust Ownership Lens: Insert Example Error"
      },
      {
        "command": "rustOwnershipLens.explainDependency",
        "title": "Rust Ownership Lens: Explain Dependency"
      },
      {
        "command": "rustOwnershipLens.expandMacro",
        "title": "Rust Ownership Lens: Expand Macro at Cursor"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "rustOwnershipLens",
          "title": "Rust Lens",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "rustOwnershipLens": [
        {
          "id": "rustOwnershipLens.view",
          "name": "Ownership Lens",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "rustOwnershipLens.explainSelection",
          "when": "editorLangId == rust",
          "group": "navigation@10"
        },
        {
          "command": "rustOwnershipLens.runCheck",
          "when": "editorLangId == rust",
          "group": "navigation@11"
        }
      ],
      "commandPalette": [
        {
          "command": "rustOwnershipLens.runCheck"
        },
        {
          "command": "rustOwnershipLens.explainSelection"
        },
        {
          "command": "rustOwnershipLens.showPanel"
        },
        {
          "command": "rustOwnershipLens.copyLastExplanation"
        },
        {
          "command": "rustOwnershipLens.insertExample"
        },
        {
          "command": "rustOwnershipLens.explainDependency"
        },
        {
          "command": "rustOwnershipLens.expandMacro"
        }
      ]
    },
    "configuration": {
      "title": "Rust Ownership Lens",
      "properties": {
        "rustOwnershipLens.cargoCommand": {
          "type": "string",
          "default": "cargo",
          "scope": "machine-overridable",
          "description": "Cargo command path used by Rust Ownership Lens."
        },
        "rustOwnershipLens.cargoArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "check",
            "--message-format=json"
          ],
          "scope": "machine-overridable",
          "description": "Arguments passed to cargo. Keep --message-format=json so diagnostics can be parsed."
        },
        "rustOwnershipLens.maxDiagnostics": {
          "type": "number",
          "default": 20,
          "minimum": 1,
          "maximum": 200,
          "description": "Maximum number of diagnostics to explain in one run."
        },
        "rustOwnershipLens.showHoverHints": {
          "type": "boolean",
          "default": true,
          "description": "Show lightweight Rust ownership hover hints."
        },
        "rustOwnershipLens.includeWarnings": {
          "type": "boolean",
          "default": false,
          "description": "Also include Rust warnings from cargo check output."
        },
        "rustOwnershipLens.runOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Run Rust Ownership Lens automatically when a Rust file is saved."
        },
        "rustOwnershipLens.showInlineTimeline": {
          "type": "boolean",
          "default": true,
          "description": "Show lightweight ownership timeline markers at the end of related diagnostic lines."
        },
        "rustOwnershipLens.hoverOnlyOnDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "Only show Rust Ownership Lens hover hints on lines that currently have Rust Ownership Lens diagnostics."
        },
        "rustOwnershipLens.useClippy": {
          "type": "boolean",
          "default": false,
          "description": "Run cargo clippy --message-format=json instead of cargo check."
        },
        "rustOwnershipLens.timeoutSeconds": {
          "type": "number",
          "default": 300,
          "minimum": 5,
          "maximum": 3600,
          "description": "Maximum seconds to wait for cargo or rustc before timing out."
        },
        "rustOwnershipLens.singleFileEdition": {
          "type": "string",
          "default": "2024",
          "enum": [
            "2015",
            "2018",
            "2021",
            "2024"
          ],
          "description": "Rust edition used when checking a standalone .rs file without Cargo.toml."
        }
      }
    }
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Rust Ownership Lens can run in untrusted workspaces, but workspace cargo command and argument overrides are ignored.",
      "restrictedConfigurations": [
        "rustOwnershipLens.cargoCommand",
        "rustOwnershipLens.cargoArgs"
      ]
    }
  },
  "devDependencies": {
    "@vscode/vsce": "^3.9.2"
  }
}
